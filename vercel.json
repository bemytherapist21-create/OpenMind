{
    "version": 2,
    "framework": null,
    "public": true,
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.py"
        },
        {
            "src": "/sandbox/(.*)",
            "dest": "https://openmind.theeverythingai.com/sandbox/$1"
        },
        {
            "src": "/sandbox-api/(.*)",
            "dest": "https://openmind.theeverythingai.com/sandbox-api/$1"
        },
        {
            "src": "/v1/(.*)",
            "dest": "/api/index.py"
        },
        {
            "src": "/(.*)",
            "dest": "/$1",
            "continue": true
        },
        {
            "src": "/(?!api|sandbox|v1|.*\\.(?:png|jpg|jpeg|gif|svg|ico|css|js|json|webmanifest)$)(.*)",
            "dest": "/index.html"
        }
    ],
    "env": {
        "OCI_VM_URL": "https://openmind.theeverythingai.com"
    }
}
