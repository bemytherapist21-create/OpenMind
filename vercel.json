{
    "version": 2,
    "framework": null,
    "public": true,
    "functions": {
        "api/*.py": {
            "runtime": "python"
        }
    },
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.py"
        },
        {
            "src": "/v1/(.*)",
            "dest": "/api/index.py"
        },
        {
            "src": "/(.*)",
            "dest": "/$1",
            "continue": true
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ],
    "env": {
        "OCI_VM_URL": "https://openmind.theeverythingai.com"
    }
}
